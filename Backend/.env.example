# Copy this file to ".env" and fill in your real values.
# The .env file itself is never committed to GitHub.

# MySQL connection.
# Format: mysql+mysqlconnector://<user>:<password>@<host>/<database>
CONNECTION_STRING = "mysql+mysqlconnector://root:your-password@localhost/ai_chat"

# OpenAI API key. Keep this on the server only - never put it in the frontend.
OPENAI_API_KEY = "your-openai-api-key"

# OpenAI model to use.
OPENAI_MODEL = "gpt-4o-mini"
